#!/usr/bin/env bash
# ================================================================
#  zync — Unified Atomic Update Orchestrator
#  Utility that handles rollback , updates , upgrades on zodium project images 
#  This should also work on fedora atomic images & ublue images
# ================================================================

set -Eeuo pipefail

VERSION="3.3.4"

# ──── Colors ────

if [[ -t 1 ]]; then
    RED="\033[31m"
    GREEN="\033[32m"
    YELLOW="\033[33m"
    BLUE="\033[34m"
    CYAN="\033[36m"
    MAGENTA="\033[35m"
    WHITE="\033[37m"
    BOLD="\033[1m"
    RESET="\033[0m"
else
    RED=""
    GREEN=""
    YELLOW=""
    BLUE=""
    CYAN=""
    MAGENTA=""
    WHITE=""
    BOLD=""
    RESET=""
fi

# ──── Extended Colors ──── #

STATUS_SUCCESS="${GREEN}[SUCCESS]${RESET}"
STATUS_FAILED="${RED}[FAILED]${RESET}"
STATUS_INFO="${BLUE}[INFO]${RESET}"
STATUS_WARNING="${YELLOW}[WARNING]${RESET}"
STATUS_DEBUG="${MAGENTA}[DEBUG]${RESET}"

# ──── Configuration ──── #

LOCKFILE="/tmp/zync-${UID}.lock"

# User-safe log location
if [[ -n "${XDG_STATE_HOME:-}" ]]; then
    LOG_FILE="$XDG_STATE_HOME/zync.log"
else
    LOG_FILE="$HOME/.local/state/zync.log"
fi

ZYNC_UNIT_DIR="/etc/systemd/system"
ZYNC_SERVICE_FILE="$ZYNC_UNIT_DIR/zync-auto-update.service"
ZYNC_TIMER_FILE="$ZYNC_UNIT_DIR/zync-auto-update.timer"
ZYNC_DEFAULT_CMD="/usr/bin/zync --rpm-ostree --no-reboot"
ZYNC_DEFAULT_INTERVAL="weekly"

# ──── State ──── #

DRY_RUN=false
QUIET=false
VERBOSE=false
NON_INTERACTIVE=false
PROMPT_REBOOT=true
MAINTAIN=false
ROLLBACK=false

RUN_RPM_OSTREE=false
RUN_FLATPAK=false
RUN_BREW=false
RUN_DISTROBOX=false
RUN_PODMAN=false
RUN_FIRMWARE=false
RUN_BOOTC=false
RUN_AUTO_UPDATES=false

REBOOT_REQUIRED=false
TOTAL_MODULES=0
SUCCESS_COUNT=0
FAIL_COUNT=0

START_TIME=$(date +%s)

# ──── Lock ──── #

exec 9>"$LOCKFILE" || {
    echo "zync: cannot create lockfile"
    exit 1
}

if ! flock -n 9; then
    echo "zync: another instance is already running"
    exit 1
fi

trap 'rm -f "$LOCKFILE"' EXIT
# ──── Logging ──── #

mkdir -p "$(dirname "$LOG_FILE")" 2>/dev/null || true
touch "$LOG_FILE" 2>/dev/null || true

# ──── ANSI stripping helper ──── #
_strip_ansi() { sed 's/\x1b\[[0-9;]*m//g'; }

log() {
    local msg="$1"
    local level="${2:-INFO}"  # default INFO
    local prefix=""

    case "$level" in
        SUCCESS) prefix="$STATUS_SUCCESS" ;;
        FAILED)  prefix="$STATUS_FAILED" ;;
        INFO)    prefix="$STATUS_INFO" ;;
        WARNING) prefix="$STATUS_WARNING" ;;
        DEBUG)   prefix="$STATUS_DEBUG" ;;
    esac

    # Terminal output
    [[ "$QUIET" = false ]] && printf '%b\n' "$prefix $msg"

    # Log file (ANSI codes stripped)
    printf '%s | %s | %s\n' "$(date '+%F %T')" "$level" "$(echo -e "$prefix $msg" | _strip_ansi)" >> "$LOG_FILE"
}

debug() { [[ "$VERBOSE" = true ]] && log "$1" DEBUG || true; }

# ──── UI ──── #

print_line() {
    printf '%*s\n' 60 '' | tr ' ' '-'
}

header() {
    echo
    echo -e "${BOLD}zync ${VERSION}${RESET}"
    print_line
}

section() {
    echo
    echo -e "${BLUE}$1${RESET}"
    print_line
}

# ──── Utilities ──── #

command_exists() {
    command -v "$1" >/dev/null 2>&1
}

confirm() {
    $NON_INTERACTIVE && return 0
    read -r -p "$1 [y/N]: " ans
    [[ "$ans" =~ ^[Yy]$ ]]
}

run_cmd() {
    if $DRY_RUN; then
        log "[DRY-RUN] $*"
        return 0
    fi
    "$@"
}

run_module() {
    local name="$1"
    shift

    TOTAL_MODULES=$((TOTAL_MODULES + 1))
    section "$name"

    local start end duration
    start=$(date +%s)

    if "$@"; then
        end=$(date +%s)
        duration=$((end - start))
        SUCCESS_COUNT=$((SUCCESS_COUNT + 1))
        log "Module completed in ${duration}s" SUCCESS
    else
        end=$(date +%s)
        duration=$((end - start))
        FAIL_COUNT=$((FAIL_COUNT + 1))
       log "Module failed in ${duration}s" FAILED
    fi
}

write_units() {
    local cmd="$1"
    local interval="$2"

    run_cmd sudo tee "$ZYNC_SERVICE_FILE" > /dev/null <<EOF
[Unit]
Description=zync Automatic Update
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
ExecStart=$cmd
StandardOutput=journal
StandardError=journal
Nice=10
IOSchedulingClass=best-effort
TimeoutStartSec=2h
EOF

    run_cmd sudo tee "$ZYNC_TIMER_FILE" > /dev/null <<EOF
[Unit]
Description=zync Automatic Update Timer
After=network-online.target
ConditionACPower=true

[Timer]
OnCalendar=$interval
Persistent=true
RandomizedDelaySec=10min

[Install]
WantedBy=timers.target
EOF
}

# ──── Modules ──── #

mod_bootc() {
    command_exists bootc || { log "bootc not found" WARNING; return 1; }
    command_exists jq   || { log "jq not found (required for bootc status parsing)" WARNING; return 1; }

    log "Checking for bootc image upgrade..." INFO
    run_cmd sudo bootc upgrade || return 1

    if ! $DRY_RUN; then
        local bootc_status
        if ! bootc_status=$(sudo bootc status --json 2>/dev/null); then
            log "Failed to query bootc status" WARNING
            return 1
        fi

        local staged_version
        staged_version=$(echo "$bootc_status" | jq -r '.status.staged.image.version // empty')

        if [[ -n "$staged_version" ]]; then
            local booted_version
            booted_version=$(echo "$bootc_status" | jq -r '.status.booted.image.version // empty')
            REBOOT_REQUIRED=true
            log "Upgrade staged: $booted_version → $staged_version" INFO
            log "Reboot required to apply new image" INFO
        else
            log "Already up to date; no new image staged" INFO
        fi
    fi
}

mod_rpm_ostree() {
    command_exists rpm-ostree || { log "rpm-ostree not found" WARNING; return 1; }
    command_exists jq         || { log "jq not found (required for rpm-ostree status parsing)" WARNING; return 1; }

    log "Checking for rpm-ostree upgrade..." INFO
    run_cmd sudo rpm-ostree upgrade || return 1

    if ! $DRY_RUN; then
        local ostree_status
        if ! ostree_status=$(rpm-ostree status --json 2>/dev/null); then
            log "Failed to query rpm-ostree status" WARNING
            return 1
        fi

        local staged
        staged=$(echo "$ostree_status" | jq '[.deployments[] | select(.staged == true)] | length')

        if [[ "$staged" -gt 0 ]]; then
            local booted_version staged_version
            booted_version=$(echo "$ostree_status" | jq -r '.deployments[] | select(.booted == true) | .version // empty')
            staged_version=$(echo "$ostree_status"  | jq -r '.deployments[] | select(.staged == true) | .version // empty')
            REBOOT_REQUIRED=true
            log "Upgrade staged: $booted_version → $staged_version" INFO
            log "Reboot required to apply new deployment" INFO
        else
            log "Already up to date; no new deployment staged" INFO
        fi
    fi

    if $MAINTAIN; then
        run_cmd sudo rpm-ostree cleanup -m || true
    fi
}

mod_flatpak() {
    command_exists flatpak || { log "flatpak not found" WARNING; return 1; }

    run_cmd flatpak update -y || return 1

    if $MAINTAIN; then
        run_cmd flatpak uninstall --unused -y || true
    fi
}

mod_brew() {
    command_exists brew || { log "brew not found" WARNING; return 1; }

    run_cmd brew update || return 1

    if ! run_cmd brew upgrade; then
        log "brew upgrade returned non-zero (possibly nothing to upgrade)" WARNING
    fi

    if $MAINTAIN; then
        run_cmd brew cleanup || true
        run_cmd brew autoremove || true
    fi

    return 0
}

mod_distrobox() {
    command_exists distrobox || { log "distrobox not found" WARNING; return 1; }
    if ! run_cmd distrobox upgrade --all; then
        log "Distrobox returned non-zero (possibly nothing to upgrade)" WARNING
    fi
    return 0
}

mod_podman() {
    command_exists podman || { log "podman not found" WARNING; return 1; }

    run_cmd podman auto-update || true

    if $MAINTAIN; then
        run_cmd podman image prune -f || true
        run_cmd podman container prune -f || true
        run_cmd podman system prune -f || true
    fi

    return 0
}

mod_firmware() {
    command_exists fwupdmgr || { log "fwupdmgr not found" WARNING; return 1; }

    run_cmd sudo fwupdmgr refresh --force || true

    if ! run_cmd sudo fwupdmgr update; then
        log "fwupdmgr update returned non-zero (possibly no updates)" WARNING
    fi

    if ! $DRY_RUN; then
        if fwupdmgr get-updates | grep -qi reboot; then
           REBOOT_REQUIRED=true
        fi
    fi

    return 0
}

mod_auto_updates() {
    local is_enabled=false
    systemctl is-enabled zync-auto-update.timer &>/dev/null && is_enabled=true

    if $is_enabled; then
        local current_interval current_cmd next_run friendly
        current_interval=$(grep -m1 "OnCalendar=" "$ZYNC_TIMER_FILE" 2>/dev/null | cut -d= -f2 || echo "unknown")
        current_cmd=$(grep -m1 "ExecStart=" "$ZYNC_SERVICE_FILE" 2>/dev/null | cut -d= -f2- || echo "unknown")
        next_run=$(systemctl show zync-auto-update.timer -p NextElapseUSecRealtime 2>/dev/null \
            | cut -d= -f2 || echo "unknown")
        [[ -z "$next_run" ]] && next_run="unknown"

        case "$current_interval" in
            daily)    friendly="Daily" ;;
            weekly)   friendly="Weekly" ;;
            *01,15*) friendly="Fortnightly" ;;
            *)        friendly="$current_interval" ;;
        esac

        printf "  %-20s %b\n" "Status:"   "${GREEN}enabled${RESET}"
        printf "  %-20s %s\n" "Schedule:" "$friendly"
        printf "  %-20s %s\n" "Command:"  "$current_cmd"
        printf "  %-20s %s\n" "Next run:" "$next_run"
        echo

        echo -e "  ${YELLOW}[1]${RESET} Disable automatic updates"
        echo -e "  ${YELLOW}[2]${RESET} Edit automatic updates"
        echo -e "  ${YELLOW}[3]${RESET} Cancel"
        echo
        read -r -p "  Choose [1/2/3]: " choice

        case "$choice" in
            1)
                run_cmd sudo systemctl disable --now zync-auto-update.timer 2>/dev/null || true
                run_cmd sudo systemctl stop zync-auto-update.service 2>/dev/null || true
                run_cmd sudo rm -f "$ZYNC_SERVICE_FILE" "$ZYNC_TIMER_FILE"
                run_cmd sudo systemctl daemon-reload
                log "Automatic updates disabled and unit files removed" SUCCESS
                ;;
            2)
                echo
                echo -e "  Current schedule: ${CYAN}$friendly${RESET}"
                echo
                echo -e "  How often should automatic updates run?"
                echo -e "    ${CYAN}[1]${RESET} Daily       — every day"
                echo -e "    ${CYAN}[2]${RESET} Weekly      — every week"
                echo -e "    ${CYAN}[3]${RESET} Fortnightly — every 14 days"
                echo
                read -r -p "  Choose [1/2/3, default: keep current]: " interval_choice
                case "$interval_choice" in
                    1) new_interval="daily" ;;
                    2) new_interval="weekly" ;;
                    3) new_interval="*-*-01,15 00:00:00" ;;
                    *) new_interval="$current_interval" ;;
                esac

                if ! systemd-analyze calendar "$new_interval" >/dev/null 2>&1; then
                    log "Invalid schedule: $new_interval" WARNING
                    return 1
                fi

                echo
                echo -e "  Current command: ${CYAN}$current_cmd${RESET}"
                read -r -p "  New command [leave blank to keep]: " new_cmd
                new_cmd="${new_cmd:-$current_cmd}"

                if [[ "$new_cmd" =~ [\;\&\|\$\`] ]]; then
                   log "Shell operators not allowed in command" WARNING
                   return 1
                fi

                if ! command -v "${new_cmd%% *}" >/dev/null 2>&1; then
                    log "Command not found: ${new_cmd%% *}" WARNING
                    return 1
                fi

                write_units "$new_cmd" "$new_interval" || return 1
                run_cmd sudo systemctl daemon-reload
                run_cmd sudo systemctl restart zync-auto-update.timer || return 1

                case "$new_interval" in
                    daily)    friendly="Daily" ;;
                    weekly)   friendly="Weekly" ;;
                    *01,15*) friendly="Fortnightly" ;;
                esac
                log "Automatic updates updated" SUCCESS
                log "Schedule: $friendly" INFO
                log "Command:  $new_cmd" INFO
                ;;
            *)
                log "Cancelled" INFO
                return 0
                ;;
        esac

    else
        printf "  %-20s %b\n" "Status:" "${RED}disabled${RESET}"
        echo

        read -r -p "  Enable automatic updates? [y/N]: " ans
        [[ "$ans" =~ ^[Yy]$ ]] || { log "Cancelled" INFO; return 0; }

        echo
        echo -e "  How often should automatic updates run?"
        echo -e "    ${CYAN}[1]${RESET} Daily       — every day"
        echo -e "    ${CYAN}[2]${RESET} Weekly      — every week"
        echo -e "    ${CYAN}[3]${RESET} Fortnightly — every 14 days"
        echo
        read -r -p "  Choose [1/2/3, default: 2]: " interval_choice
        case "$interval_choice" in
            1) new_interval="daily" ;;
            3) new_interval="*-*-01,15 00:00:00" ;;
            *) new_interval="weekly" ;;
        esac

        if ! systemd-analyze calendar "$new_interval" >/dev/null 2>&1; then
            log "Invalid schedule: $new_interval" WARNING
            return 1
        fi

        echo
        echo -e "  Default command: ${CYAN}$ZYNC_DEFAULT_CMD${RESET}"
        read -r -p "  Command to run [leave blank for default]: " new_cmd
        new_cmd="${new_cmd:-$ZYNC_DEFAULT_CMD}"

        if [[ "$new_cmd" =~ [\;\&\|\$\`] ]]; then
            log "Shell operators not allowed in command" WARNING
            return 1
        fi


        if ! command -v "${new_cmd%% *}" >/dev/null 2>&1; then
            log "Command not found: ${new_cmd%% *}" WARNING
            return 1
        fi

        write_units "$new_cmd" "$new_interval" || return 1
        run_cmd sudo systemctl daemon-reload
        run_cmd sudo systemctl enable --now zync-auto-update.timer || return 1

        case "$new_interval" in
            daily)    friendly="Daily" ;;
            weekly)   friendly="Weekly" ;;
            *01,15*) friendly="Fortnightly" ;;
        esac
        log "Automatic updates enabled" SUCCESS
        log "Schedule: $friendly" INFO
        log "Command:  $new_cmd" INFO
    fi
}

mod_rollback() {
    command_exists rpm-ostree || { log "rpm-ostree not found" WARNING; return 1; }
    command_exists jq         || { log "jq not found (required for rollback check)" WARNING; return 1; }

    local ostree_status deployment_count

    if ! ostree_status=$(rpm-ostree status --json 2>/dev/null); then
        log "Failed to query rpm-ostree status" WARNING
        return 1
    fi

    deployment_count=$(echo "$ostree_status" | jq '.deployments | length')

    if [[ "$deployment_count" -lt 2 ]]; then
        log "No previous deployment available to roll back to" WARNING
        return 1
    fi

    # Identify booted deployment index
    local booted_index
    booted_index=$(echo "$ostree_status" | jq -r '
        .deployments
        | to_entries[]
        | select(.value.booted == true)
        | .key
    ')

    # Determine rollback target index
    local target_index
    if [[ "$booted_index" -eq 0 ]]; then
        target_index=1
    else
        target_index=0
    fi

    local current_version previous_version
    current_version=$(echo "$ostree_status" | jq -r ".deployments[$booted_index].version // \"unknown\"")
    previous_version=$(echo "$ostree_status" | jq -r ".deployments[$target_index].version // \"unknown\"")

    log "Rolling back: $current_version → $previous_version" INFO

    if ! $NON_INTERACTIVE; then
        if ! confirm "Proceed with rollback?"; then
            log "Rollback cancelled" INFO
            return 0
        fi
    fi

    run_cmd sudo rpm-ostree rollback || return 1

    REBOOT_REQUIRED=true
    log "Rollback staged successfully" SUCCESS
    log "Reboot required to boot into previous deployment" INFO
}

# ──── Help ──── #

show_help() {
    printf "%b\n" "${BOLD}${BLUE}zync ${VERSION}${RESET}"
    printf "%b\n\n" "${BOLD}Unified Atomic Update Orchestrator${RESET}"

    printf "%b\n" "${YELLOW}USAGE:${RESET}"
    printf "%b\n\n" "  zync [OPTIONS]"

    printf "%b\n" "${YELLOW}MODULE OPTIONS:${RESET}"
    printf "%b\n" "  ${BLUE}--all${RESET}          Run all modules"
    printf "%b\n" "  ${BLUE}--rpm-ostree${RESET}   Update rpm-ostree system"
    printf "%b\n" "  ${BLUE}--flatpak${RESET}      Update Flatpak apps"
    printf "%b\n" "  ${BLUE}--brew${RESET}         Update Homebrew packages"
    printf "%b\n" "  ${BLUE}--distrobox${RESET}    Upgrade all Distrobox containers"
    printf "%b\n" "  ${BLUE}--podman${RESET}       Update Podman containers/images"
    printf "%b\n" "  ${BLUE}--firmware${RESET}     Update firmware via fwupdmgr"
    printf "%b\n" "  ${BLUE}--bootc${RESET}        Update system via bootc (rpm-ostree successor)"
    printf "\n"

    printf "%b\n" "${YELLOW}SPECIAL:${RESET}"
    printf "%b\n" "  ${BLUE}--rollback${RESET}     Rollback rpm-ostree deployment"
    printf "%b\n" "  ${BLUE}--auto-updates${RESET} Interactively manage automatic updates"
    printf "\n"

    printf "%b\n" "${YELLOW}MODES:${RESET}"
    printf "%b\n" "  ${BLUE}--maintain${RESET}     Remove unused packages/images"
    printf "%b\n" "  ${BLUE}--dry-run${RESET}      Show commands without executing"
    printf "%b\n" "  ${BLUE}--no-reboot${RESET}    Skip automatic reboot even if required"
    printf "\n"

    printf "%b\n" "${YELLOW}OUTPUT:${RESET}"
    printf "%b\n" "  ${BLUE}--quiet${RESET}        Suppress terminal output"
    printf "%b\n" "  ${BLUE}--verbose${RESET}      Show debug messages"
    printf "\n"

    printf "%b\n" "${YELLOW}GENERAL:${RESET}"
    printf "%b\n" "  ${BLUE}--version${RESET}      Show version"
    printf "%b\n" "  ${BLUE}--help${RESET}         Show this help"
    printf "\n"

    printf "%b\n" "${YELLOW}EXAMPLES:${RESET}"
    printf "%b\n" "  ${GREEN}# Upgrade everything interactively${RESET}"
    printf "%b\n" "  zync --all"
    printf "\n"

    printf "%b\n" "  ${GREEN}# Update system and firmware, skip reboot${RESET}"
    printf "%b\n" "  zync --rpm-ostree --firmware --no-reboot"
    printf "\n"

    printf "%b\n" "  ${GREEN}# Dry-run all modules without making changes${RESET}"
    printf "%b\n" "  zync --all --dry-run"
    printf "\n"

    printf "%b\n" "  ${GREEN}# Rollback rpm-ostree deployment${RESET}"
    printf "%b\n" "  zync --rollback"
    printf "\n"
}

# ──── Argument Parsing ──── #

while [[ $# -gt 0 ]]; do
    case "$1" in
        --all) RUN_RPM_OSTREE=true; RUN_FLATPAK=true; RUN_BREW=true; RUN_DISTROBOX=true; RUN_PODMAN=true; RUN_FIRMWARE=true ;;
        --rpm-ostree) RUN_RPM_OSTREE=true ;;
        --flatpak) RUN_FLATPAK=true ;;
        --brew) RUN_BREW=true ;;
        --distrobox) RUN_DISTROBOX=true ;;
        --podman) RUN_PODMAN=true ;;
        --firmware) RUN_FIRMWARE=true ;;
        --bootc) RUN_BOOTC=true ;;
        --auto-updates) RUN_AUTO_UPDATES=true ;;
        --maintain) MAINTAIN=true ;;
        --rollback) ROLLBACK=true ;;
        --dry-run) DRY_RUN=true ;;
        --quiet) QUIET=true ;;
        --verbose) VERBOSE=true ;;
        --no-reboot) PROMPT_REBOOT=false ;;
        --version) echo "zync $VERSION"; exit 0 ;;
        --help) show_help; exit 0 ;;
        *) echo "Unknown option: $1"; exit 1 ;;
    esac
    shift
done

# ──── Handle Flag Conflicts ──── #

if [[ "$QUIET" = true && "$VERBOSE" = true ]]; then
    log "Both --quiet and --verbose passed; forcing VERBOSE=false" WARNING
    VERBOSE=false
fi

# ──── Default Module Selection ──── #

if ! $RUN_RPM_OSTREE && ! $RUN_FLATPAK && ! $RUN_BREW && \
   ! $RUN_DISTROBOX && ! $RUN_PODMAN && ! $RUN_FIRMWARE && \
   ! $RUN_BOOTC && ! $ROLLBACK && ! $RUN_AUTO_UPDATES; then

    RUN_RPM_OSTREE=true
    RUN_FLATPAK=true
    RUN_BREW=true
    RUN_DISTROBOX=true
    RUN_PODMAN=true
    RUN_FIRMWARE=true
fi

# ──── Execution ──── #

header

# ──── Guard: auto-updates exclusive ──── #
if $RUN_AUTO_UPDATES; then
    if $RUN_RPM_OSTREE || $RUN_BOOTC || $RUN_FLATPAK || $RUN_BREW || \
       $RUN_DISTROBOX  || $RUN_PODMAN || $RUN_FIRMWARE || $ROLLBACK; then
        log "--auto-updates cannot be combined with other flags" WARNING
        exit 1
    fi
    run_module "Automatic Updates" mod_auto_updates
    exit $([[ $FAIL_COUNT -gt 0 ]] && echo 2 || echo 0)
fi

# ──── Guard: rollback exclusive ──── #
if $ROLLBACK; then
    if $RUN_RPM_OSTREE || $RUN_FLATPAK || $RUN_BREW || $RUN_DISTROBOX || \
       $RUN_PODMAN || $RUN_FIRMWARE || $RUN_BOOTC; then
        log "--rollback ignores all other module flags" WARNING
    fi
    RUN_RPM_OSTREE=false; RUN_FLATPAK=false; RUN_BREW=false
    RUN_DISTROBOX=false;  RUN_PODMAN=false;  RUN_FIRMWARE=false
    RUN_BOOTC=false

    run_module "rpm-ostree Rollback" mod_rollback
fi

# ──── Run normal modules ──── #
$RUN_RPM_OSTREE && run_module "Rpm-ostree" mod_rpm_ostree
$RUN_FLATPAK && run_module "Flatpak" mod_flatpak
$RUN_BREW && run_module "Homebrew" mod_brew
$RUN_DISTROBOX && run_module "Distrobox" mod_distrobox
$RUN_PODMAN && run_module "Podman" mod_podman
$RUN_FIRMWARE && run_module "Firmware" mod_firmware
$RUN_BOOTC && run_module "Bootc" mod_bootc

# ──── Summary ──── #

END_TIME=$(date +%s)
DURATION=$((END_TIME - START_TIME))

section "SUMMARY"

printf "  %-18s %s\n" "Modules Executed:" "$TOTAL_MODULES"
printf "  %-18s %b\n" "Successful:" "${GREEN}${SUCCESS_COUNT}${RESET}"
printf "  %-18s %b\n" "Failed:" "${RED}${FAIL_COUNT}${RESET}"
printf "  %-18s %b\n" "Reboot Required:" "$([ "$REBOOT_REQUIRED" = true ] && echo "${YELLOW}YES${RESET}" || echo "${GREEN}NO${RESET}")"
printf "  %-18s %ss\n" "Duration:" "$DURATION"

if $PROMPT_REBOOT && $REBOOT_REQUIRED; then
    if confirm "Reboot now?"; then
        run_cmd sudo reboot
    fi
elif $REBOOT_REQUIRED; then
    log "Reboot skipped due to --no-reboot; please reboot manually." WARNING
fi

[[ $FAIL_COUNT -gt 0 ]] && exit 2
exit 0