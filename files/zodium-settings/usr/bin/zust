#!/usr/bin/env bash
set -Eeuo pipefail

VERSION="1.0.0"

# ---- Colors ----
if [[ -t 1 ]]; then
    RED="\033[31m"
    GREEN="\033[32m"
    YELLOW="\033[33m"
    BLUE="\033[34m"
    CYAN="\033[36m"
    MAGENTA="\033[35m"
    WHITE="\033[37m"
    BOLD="\033[1m"
    RESET="\033[0m"
else
    RED="" GREEN="" YELLOW="" BLUE="" CYAN="" MAGENTA="" WHITE="" BOLD="" RESET=""
fi

# ---- Help ----
show_help() {
    printf "%b — Script Launcher\n\n" "${BOLD}zust ${VERSION}${RESET}"
    printf "Usage:\n"
    printf "  %b --choose%b         Launch interactive script chooser\n" "${BLUE}" "${RESET}"
    printf "  %b --list%b           List all available scripts\n" "${BLUE}" "${RESET}"
    printf "  %b --help%b           Show this help\n\n" "${BLUE}" "${RESET}"

    printf "Flags:\n"
    printf "  %b--choose%b   Interactive selection with preview\n" "${BLUE}" "${RESET}"
    printf "  %b--list%b     List scripts (no preview)\n" "${BLUE}" "${RESET}"
    printf "  %b--help%b     Show this help\n\n" "${BLUE}" "${RESET}"

    printf "Scripts are searched in:\n"
    printf "  /etc/zust-scripts (preferred)\n"
    printf "  /usr/lib/zust-scripts\n"
}

# ---- Script directories ----
DIRS=(/etc/zust-scripts /usr/lib/zust-scripts)

# ---- Gather scripts, deduplicate (prefer /etc) ----
declare -A scripts
for d in "${DIRS[@]}"; do
    [[ -d "$d" ]] || continue
    for f in "$d"/*.sh; do
        [[ -f "$f" ]] || continue
        name=$(basename "$f")
        scripts["$name"]="$f"  # /etc will overwrite /usr/lib automatically
    done
done

if [[ ${#scripts[@]} -eq 0 ]]; then
    echo -e "${RED}[ERROR]${RESET} No zust scripts found in ${DIRS[*]}"
    exit 1
fi

# ---- List-only mode ----
if [[ "${1:-}" == "--list" ]]; then
    echo "zust ${VERSION}"
    echo "Available scripts:"
    for s in "${!scripts[@]}"; do
        echo "  $s"
    done | sort
    exit 0
fi

# ---- Choose mode ----
if [[ "${1:-}" != "--choose" ]]; then
    show_help
    exit 0
fi

# ---- Check dependencies ----
command -v fzf >/dev/null 2>&1 || { echo "fzf not found"; exit 1; }

USE_BAT=false
if command -v bat >/dev/null 2>&1; then
    USE_BAT=true
fi

# ---- Prepare fzf list ----
SCRIPT_NAMES=()
for s in "${!scripts[@]}"; do
    SCRIPT_NAMES+=("$s")
done
IFS=$'\n' SORTED_SCRIPTS=($(sort <<<"${SCRIPT_NAMES[*]}"))
unset IFS

# ---- Launch fzf ----
clear
SELECTED=$(printf '%s\n' "${SORTED_SCRIPTS[@]}" | fzf \
    --ansi \
    --reverse \
    --no-multi \
    --prompt="Select a script (Ctrl-C to quit) > " \
    --preview-window=right:70%:wrap \
    --preview="[[ \$USE_BAT == true ]] && bat --style=numbers --color=always {} || cat {}" \
    --bind "change:reload:scripts[{}]") || exit 0

SCRIPT_PATH="${scripts[$SELECTED]}"

clear
echo -e "${GREEN}Running script:${RESET} $SELECTED"
echo

exec bash "$SCRIPT_PATH"