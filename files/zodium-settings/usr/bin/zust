#!/usr/bin/env bash
set -Eeuo pipefail

VERSION="1.0.0"

# ---- Colors ----
if [[ -t 1 ]]; then
    RED="\033[31m"
    GREEN="\033[32m"
    YELLOW="\033[33m"
    BLUE="\033[34m"
    MAGENTA="\033[35m"
    CYAN="\033[36m"
    WHITE="\033[37m"
    BOLD="\033[1m"
    RESET="\033[0m"
else
    RED="" GREEN="" YELLOW="" BLUE="" MAGENTA="" CYAN="" WHITE="" BOLD="" RESET=""
fi

# ---- Extended Colors ----
STATUS_SUCCESS="${GREEN}[SUCCESS]${RESET}"
STATUS_FAILED="${RED}[FAILED]${RESET}"
STATUS_INFO="${BLUE}[INFO]${RESET}"
STATUS_WARNING="${YELLOW}[WARNING]${RESET}"
STATUS_DEBUG="${MAGENTA}[DEBUG]${RESET}"

# ---- Configuration ----
ZUST_DIR="/usr/lib/zust-scripts"
LOCKFILE="/tmp/zust-${UID}.lock"
if [[ -n "${XDG_STATE_HOME:-}" ]]; then
    LOG_FILE="$XDG_STATE_HOME/zust.log"
else
    LOG_FILE="$HOME/.local/state/zust.log"
fi
mkdir -p "$(dirname "$LOG_FILE")" 2>/dev/null || true
touch "$LOG_FILE" 2>/dev/null || true

# ---- State ----
DRY_RUN=false
QUIET=false
VERBOSE=false
NON_INTERACTIVE=false
INTERACTIVE=false

TOTAL_MODULES=0
SUCCESS_COUNT=0
FAIL_COUNT=0

START_TIME=$(date +%s)

# ---- Lock ----
exec 9>"$LOCKFILE" || { echo "zust: cannot create lockfile"; exit 1; }
if ! flock -n 9; then
    echo "zust: another instance is already running"
    exit 1
fi
trap 'rm -f "$LOCKFILE"' EXIT

# ---- ANSI stripping helper ----
_strip_ansi() { sed 's/\x1b\[[0-9;]*m//g'; }

log() {
    local msg="$1" level="${2:-INFO}" prefix=""
    case "$level" in
        SUCCESS) prefix="$STATUS_SUCCESS" ;;
        FAILED) prefix="$STATUS_FAILED" ;;
        INFO) prefix="$STATUS_INFO" ;;
        WARNING) prefix="$STATUS_WARNING" ;;
        DEBUG) prefix="$STATUS_DEBUG" ;;
    esac
    [[ "$QUIET" = false ]] && printf '%b\n' "$prefix $msg"
    printf '%s | %s | %s\n' "$(date '+%F %T')" "$level" "$(echo -e "$prefix $msg" | _strip_ansi)" >> "$LOG_FILE"
}

debug() { [[ "$VERBOSE" = true ]] && log "$1" DEBUG || true; }

# ---- UI ----
print_line() { printf '%*s\n' 60 '' | tr ' ' '-'; }
header() { echo; echo -e "${BOLD}zust ${VERSION}${RESET}"; print_line; }
section() { echo; echo -e "${BLUE}$1${RESET}"; print_line; }

# ---- Utilities ----
command_exists() { command -v "$1" >/dev/null 2>&1; }
confirm() { $NON_INTERACTIVE && return 0; read -r -p "$1 [y/N]: " ans; [[ "$ans" =~ ^[Yy]$ ]]; }
run_cmd() { $DRY_RUN && log "[DRY-RUN] $*" INFO || "$@"; }

# ---- Modules ----
list_scripts() {
    TOTAL_MODULES=$((TOTAL_MODULES+1))
    section "Listing zust Scripts"
    scripts=("$ZUST_DIR"/*.sh)
    [[ ${#scripts[@]} -gt 0 ]] || { log "No scripts found in $ZUST_DIR" WARNING; return 1; }
    for s in "${scripts[@]}"; do
        printf "  %s\n" "$(basename "$s")"
    done
    SUCCESS_COUNT=$((SUCCESS_COUNT+1))
}

run_script() {
    local name="$1"; shift
    TOTAL_MODULES=$((TOTAL_MODULES+1))
    section "Running Script: $name"

    local path="$ZUST_DIR/$name"
    [[ -f "$path" && -x "$path" ]] || { log "Script '$name' not found or not executable" FAILED; FAIL_COUNT=$((FAIL_COUNT+1)); return 1; }

    if $INTERACTIVE; then
        log "Interactive mode selected for $name" INFO
    fi

    local start end duration
    start=$(date +%s)
    if run_cmd "$path" "$@"; then
        end=$(date +%s)
        duration=$((end-start))
        SUCCESS_COUNT=$((SUCCESS_COUNT+1))
        log "Script completed in ${duration}s" SUCCESS
    else
        end=$(date +%s)
        duration=$((end-start))
        FAIL_COUNT=$((FAIL_COUNT+1))
        log "Script failed in ${duration}s" FAILED
    fi
}

# ---- Help ----
show_help() {
    header
    printf "%b\n" "${BOLD}zust — Run and manage bash scripts in ${ZUST_DIR}${RESET}"
    echo
    printf "%b\n" "${YELLOW}USAGE:${RESET}"
    echo "  zust [OPTIONS] <command> [args...]"
    echo
    printf "%b\n" "${YELLOW}COMMANDS:${RESET}"
    echo "  list                   List available scripts"
    echo "  run <script> [args...] Run a specific script"
    echo "  help                   Show this help"
    echo
    printf "%b\n" "${YELLOW}OPTIONS:${RESET}"
    echo "  --dry-run       Show commands without executing"
    echo "  --verbose       Show debug messages"
    echo "  --quiet         Suppress terminal output"
    echo "  --yes           Assume yes for prompts"
    echo "  --interactive   Choose script interactively"
    echo "  --version       Show version"
    echo "  --help          Show this help"
    echo
    printf "%b\n" "${YELLOW}EXAMPLES:${RESET}"
    echo "  zust list"
    echo "  zust run myscript.sh arg1 arg2"
    echo "  zust --interactive run"
    echo
}

# ---- Argument Parsing ----
CMD=""
ARGS=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        --dry-run) DRY_RUN=true ;;
        --verbose) VERBOSE=true ;;
        --quiet) QUIET=true ;;
        --yes) NON_INTERACTIVE=true ;;
        --interactive) INTERACTIVE=true ;;
        --version) echo "zust $VERSION"; exit 0 ;;
        --help) show_help; exit 0 ;;
        list|run|help) CMD="$1"; shift; ARGS=("$@"); break ;;
        *) log "Unknown option: $1" WARNING; exit 1 ;;
    esac
    shift
done
[[ -n "$CMD" ]] || { show_help; exit 1; }

# ---- Execution ----
header
case "$CMD" in
    list) list_scripts ;;
    run)
        if $INTERACTIVE; then
            scripts=("$ZUST_DIR"/*.sh)
            [[ ${#scripts[@]} -gt 0 ]] || { log "No scripts found for interactive selection" FAILED; exit 1; }
            echo "Select a script to run:"
            idx=1
            declare -A imap
            for s in "${scripts[@]}"; do
                echo "  [$idx] $(basename "$s")"
                imap[$idx]="$s"
                ((idx++))
            done
            read -rp "Choice [1-$((idx-1))]: " choice
            SCRIPT="${imap[$choice]:-}"
            [[ -n "$SCRIPT" ]] || { log "Invalid selection" FAILED; exit 1; }
            run_script "$(basename "$SCRIPT")"
        else
            [[ ${#ARGS[@]} -ge 1 ]] || { log "No script specified" FAILED; exit 1; }
            run_script "${ARGS[0]}" "${ARGS[@]:1}"
        fi
        ;;
    help) show_help ;;
    *) log "Unknown command: $CMD" FAILED; exit 1 ;;
esac

# ---- Summary ----
END_TIME=$(date +%s)
DURATION=$((END_TIME-START_TIME))
section "SUMMARY"
printf "  %-18s %s\n" "Modules Executed:" "$TOTAL_MODULES"
printf "  %-18s %b\n" "Successful:" "${GREEN}${SUCCESS_COUNT}${RESET}"
printf "  %-18s %b\n" "Failed:" "${RED}${FAIL_COUNT}${RESET}"
printf "  %-18s %ss\n" "Duration:" "$DURATION"
[[ $FAIL_COUNT -gt 0 ]] && exit 2
exit 0