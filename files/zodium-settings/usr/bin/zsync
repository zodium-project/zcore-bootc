#!/usr/bin/env bash
set -Eeuo pipefail

VERSION="3.1.1"

# ---- Configuration ----

LOCKFILE="/tmp/zsync-${UID}.lock"

# User-safe log location
if [[ -n "${XDG_STATE_HOME:-}" ]]; then
    LOG_FILE="$XDG_STATE_HOME/zsync.log"
else
    LOG_FILE="$HOME/.local/state/zsync.log"
fi

# ---- State ----

DRY_RUN=false
QUIET=false
VERBOSE=false
NON_INTERACTIVE=false
PROMPT_REBOOT=true
MAINTAIN=false
ROLLBACK=false

RUN_SYSTEM=false
RUN_FLATPAK=false
RUN_BREW=false
RUN_DISTROBOX=false
RUN_PODMAN=false
RUN_FIRMWARE=false

REBOOT_REQUIRED=false
TOTAL_MODULES=0
SUCCESS_COUNT=0
FAIL_COUNT=0

START_TIME=$(date +%s)

# ---- Lock ----

exec 9>"$LOCKFILE" || {
    echo "zsync: cannot create lockfile"
    exit 1
}

if ! flock -n 9; then
    echo "zsync: another instance is already running"
    exit 1
fi

# ---- Logging ----

mkdir -p "$(dirname "$LOG_FILE")" 2>/dev/null || true
touch "$LOG_FILE" 2>/dev/null || true

log() {
    local msg="$1"
    [[ "$QUIET" = false ]] && echo "$msg"
    echo "$(date '+%F %T') | $msg" >> "$LOG_FILE"
}

debug() {
    [[ "$VERBOSE" = true ]] && log "[DEBUG] $1"
}

# ---- UI ----

print_line() {
    printf '%*s\n' 60 '' | tr ' ' '-'
}

header() {
    echo
    echo "zsync ${VERSION}"
    print_line
}

section() {
    echo
    echo "$1"
    print_line
}

# ---- Utilities ----

command_exists() {
    command -v "$1" >/dev/null 2>&1
}

confirm() {
    $NON_INTERACTIVE && return 1
    read -r -p "$1 [y/N]: " ans
    [[ "$ans" =~ ^[Yy]$ ]]
}

run_cmd() {
    if $DRY_RUN; then
        log "[DRY-RUN] $*"
        return 0
    fi
    "$@"
}

run_module() {
    local name="$1"
    shift

    TOTAL_MODULES=$((TOTAL_MODULES + 1))
    section "$name"

    local start=$(date +%s)

    if "$@"; then
        local end=$(date +%s)
        local duration=$((end - start))
        SUCCESS_COUNT=$((SUCCESS_COUNT + 1))
        log "Status: SUCCESS (${duration}s)"
    else
        local end=$(date +%s)
        local duration=$((end - start))
        FAIL_COUNT=$((FAIL_COUNT + 1))
        log "Status: FAILED (${duration}s)"
    fi
}

# ---- Modules ----

mod_system() {
    command_exists rpm-ostree || { log "rpm-ostree not found"; return 1; }

    run_cmd sudo rpm-ostree upgrade || return 1

    if rpm-ostree status | grep -q "^\s*●"; then
        REBOOT_REQUIRED=true
    fi

    $MAINTAIN && run_cmd sudo rpm-ostree cleanup -m || true
}

mod_flatpak() {
    command_exists flatpak || { log "flatpak not found"; return 1; }

    run_cmd flatpak update -y || return 1
    $MAINTAIN && run_cmd flatpak uninstall --unused -y || true
}

mod_brew() {
    command_exists brew || { log "brew not found"; return 1; }

    run_cmd brew update || return 1
    run_cmd brew upgrade || return 1

    $MAINTAIN && {
        run_cmd brew cleanup || true
        run_cmd brew autoremove || true
    }
}

mod_distrobox() {
    command_exists distrobox || { log "distrobox not found"; return 1; }
    run_cmd distrobox upgrade --all || return 1
}

mod_podman() {
    command_exists podman || { log "podman not found"; return 1; }

    run_cmd podman auto-update || true

    $MAINTAIN && {
        run_cmd podman image prune -f || true
        run_cmd podman container prune -f || true
        run_cmd podman system prune -f || true
    }
}

mod_firmware() {
    command_exists fwupdmgr || { log "fwupdmgr not found"; return 1; }

    run_cmd sudo fwupdmgr refresh || return 1
    run_cmd sudo fwupdmgr update || return 1

    if fwupdmgr get-updates | grep -qi reboot; then
        REBOOT_REQUIRED=true
    fi
}

mod_rollback() {
    command_exists rpm-ostree || { echo "rpm-ostree not found"; exit 1; }
    section "rpm-ostree Rollback"
    run_cmd sudo rpm-ostree rollback
}

# ---- Help ----

show_help() {
cat <<EOF
zsync ${VERSION}
Unified Atomic Update Orchestrator

USAGE:
  zsync [OPTIONS]

If no module options are specified, all modules are executed.

MODULE OPTIONS:
  --all
  --system
  --flatpak
  --brew
  --distrobox
  --podman
  --firmware

SPECIAL:
  --rollback

MODES:
  --maintain
  --dry-run
  --yes
  --no-reboot

OUTPUT:
  --quiet
  --verbose

GENERAL:
  --version
  --help
EOF
}

# ---- Argument Parsing ----

while [[ $# -gt 0 ]]; do
    case "$1" in
        --all) RUN_SYSTEM=true; RUN_FLATPAK=true; RUN_BREW=true; RUN_DISTROBOX=true; RUN_PODMAN=true; RUN_FIRMWARE=true ;;
        --system) RUN_SYSTEM=true ;;
        --flatpak) RUN_FLATPAK=true ;;
        --brew) RUN_BREW=true ;;
        --distrobox) RUN_DISTROBOX=true ;;
        --podman) RUN_PODMAN=true ;;
        --firmware) RUN_FIRMWARE=true ;;
        --maintain) MAINTAIN=true ;;
        --rollback) ROLLBACK=true ;;
        --dry-run) DRY_RUN=true ;;
        --quiet) QUIET=true ;;
        --verbose) VERBOSE=true ;;
        --yes) NON_INTERACTIVE=true ;;
        --no-reboot) PROMPT_REBOOT=false ;;
        --version) echo "zsync $VERSION"; exit 0 ;;
        --help) show_help; exit 0 ;;
        *) echo "Unknown option: $1"; exit 1 ;;
    esac
    shift
done

# ---- Default Module Selection ----

if ! $RUN_SYSTEM && ! $RUN_FLATPAK && ! $RUN_BREW && \
   ! $RUN_DISTROBOX && ! $RUN_PODMAN && ! $RUN_FIRMWARE && \
   ! $ROLLBACK; then

    RUN_SYSTEM=true
    RUN_FLATPAK=true
    RUN_BREW=true
    RUN_DISTROBOX=true
    RUN_PODMAN=true
    RUN_FIRMWARE=true
fi

# ---- Execution ----

header

if $ROLLBACK; then
    mod_rollback
    exit 0
fi

$RUN_SYSTEM && run_module "rpm-ostree" mod_system
$RUN_FLATPAK && run_module "Flatpak" mod_flatpak
$RUN_BREW && run_module "Homebrew" mod_brew
$RUN_DISTROBOX && run_module "Distrobox" mod_distrobox
$RUN_PODMAN && run_module "Podman" mod_podman
$RUN_FIRMWARE && run_module "Firmware" mod_firmware

# ---- Summary ----

END_TIME=$(date +%s)
DURATION=$((END_TIME - START_TIME))

section "SUMMARY"

printf "  %-18s %s\n" "Modules Executed:" "$TOTAL_MODULES"
printf "  %-18s %s\n" "Successful:" "$SUCCESS_COUNT"
printf "  %-18s %s\n" "Failed:" "$FAIL_COUNT"
printf "  %-18s %s\n" "Reboot Required:" "$REBOOT_REQUIRED"
printf "  %-18s %ss\n" "Duration:" "$DURATION"

if $PROMPT_REBOOT && $REBOOT_REQUIRED; then
    if confirm "Reboot now?"; then
        sudo reboot
    fi
fi

[[ $FAIL_COUNT -gt 0 ]] && exit 2
exit 0