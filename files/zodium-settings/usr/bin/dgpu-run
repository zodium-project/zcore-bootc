#!/usr/bin/env bash
# ================================================================
#  dgpu-run — Prime-run alternative for zodium project 
#  should work on fedora , fedora atomic & ublue images too.
#  sets PRIME variables/env-vars for apps to launch. (generic tool)
# ================================================================

set -o pipefail
shopt -s nullglob

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# COLOUR PALETTE  (bright, vivid — only when stdout is a TTY)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
if [[ -t 1 ]]; then
    R=$'\e[0m'  BD=$'\e[1m'  DM=$'\e[2m'

    C_GRY=$'\e[38;5;240m'   # muted separator / labels
    C_WHT=$'\e[38;5;255m'   # bright white
    C_CYN=$'\e[38;5;51m'    # vivid cyan   — headers
    C_YLW=$'\e[38;5;226m'   # vivid yellow — flags/options
    C_GRN=$'\e[38;5;82m'    # vivid green  — NVIDIA / dGPU / yes
    C_RED=$'\e[38;5;196m'   # vivid red    — AMD / error
    C_BLU=$'\e[38;5;39m'    # vivid blue   — Intel / iGPU
    C_MAG=$'\e[38;5;213m'   # vivid pink   — VRAM
    C_ORG=$'\e[38;5;208m'   # orange       — warnings / temp

    NV_COL="$C_GRN"
    AMD_COL="$C_RED"
    INTEL_COL="$C_BLU"
    IGPU_COL="$C_BLU"
    DGPU_COL="$C_GRN"
    SOLE_COL="$C_YLW"
    OK_COL="$C_GRN"
    NO_COL="$C_GRY"
    WARN_COL="$C_ORG"
    ERR_COL="$C_RED"
else
    R="" BD="" DM=""
    C_GRY="" C_WHT="" C_CYN="" C_YLW="" C_GRN="" C_RED="" C_BLU="" C_MAG="" C_ORG=""
    NV_COL="" AMD_COL="" INTEL_COL="" IGPU_COL="" DGPU_COL="" SOLE_COL=""
    OK_COL="" NO_COL="" WARN_COL="" ERR_COL=""
fi

say()  { printf '%b\n' "$*"; }
errmsg(){ printf '%b\n' "${ERR_COL}${BD}error:${R} $*" >&2; }
die()  { errmsg "$*"; exit 1; }
warn() { printf '%b\n' "  ${WARN_COL}warning:${R} $*" >&2; }

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# HELP
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
show_help() {
    say ""
    say "  ${BD}${C_CYN}dgpu-run${R}  ${C_GRY}─  GPU selection & PRIME offload launcher${R}"
    say ""
    say "  ${BD}${C_WHT}Usage${R}"
    say "    dgpu-run ${C_GRY}[options]${R} ${C_GRY}[command [args...]]${R}"
    say ""
    say "  ${BD}${C_WHT}Options${R}"
    say "    ${C_YLW}-v${R}, ${C_YLW}--verbose${R}              Show detailed GPU info"
    say "    ${C_YLW}--use-device ${C_GRY}<id>${R}          Target a specific GPU"
    say "      ${C_GRY}card0, card1 …${R}             by DRM node name"
    say "      ${C_GRY}nvidia | amd | intel${R}        by driver"
    say "    ${C_YLW}--interactive-choose${R}           Pick GPU from a menu"
    say "    ${C_YLW}--list-devices${R}                 List all detected GPUs"
    say "    ${C_YLW}-h${R}, ${C_YLW}--help${R}                  Show this help"
    say ""
    say "  ${BD}${C_WHT}Behaviour${R}"
    say "    ${C_GRY}no command${R}  →  print detection summary"
    say "    ${C_GRY}command${R}     →  run on dGPU ${C_GRY}(or forced/chosen GPU)${R}"
    say ""
    say "  ${BD}${C_WHT}Examples${R}"
    say "    dgpu-run                               ${C_GRY}# detection summary${R}"
    say "    dgpu-run ${C_YLW}-v${R}                           ${C_GRY}# verbose info${R}"
    say "    dgpu-run ${C_YLW}--list-devices${R}               ${C_GRY}# enumerate GPUs${R}"
    say "    dgpu-run ${C_YLW}--use-device${R} nvidia glxinfo  ${C_GRY}# force NVIDIA${R}"
    say "    dgpu-run ${C_YLW}--interactive-choose${R} blender ${C_GRY}# pick GPU${R}"
    say "    dgpu-run vkcube                        ${C_GRY}# auto dGPU${R}"
    say ""
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ARGUMENT PARSING
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
verbose=0 selected_device="" interactive=0 list_devices=0
cmd_args=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        -v|--verbose)         verbose=1; shift ;;
        --use-device)         [[ -n "${2-}" ]] || die "--use-device requires an argument"
                              selected_device="$2"; shift 2 ;;
        --interactive-choose) interactive=1; shift ;;
        --list-devices)       list_devices=1; shift ;;
        -h|--help)            show_help; exit 0 ;;
        --)                   shift; cmd_args+=("$@"); break ;;
        -*)                   die "Unknown option: $1" ;;
        *)                    cmd_args+=("$@"); break ;;
    esac
done

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# SYSFS HELPERS  (all inside functions — no bare `local`)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
sysfs_read() {
    local p="$1" d="${2:-}"
    if [[ -r "$p" ]]; then
        local v; v=$(<"$p") && printf '%s' "${v// /}" || printf '%s' "$d"
    else
        printf '%s' "$d"
    fi
}

pci_bus_decimal() {
    local pci="$1" bus
    bus="${pci#*:}"; bus="${bus%%:*}"
    [[ "$bus" =~ ^[0-9a-fA-F]+$ ]] && printf '%d' "$(( 16#$bus ))" || printf '0'
}

pci_class() {
    local raw; raw=$(sysfs_read "$1/class" "0x000000")
    raw="${raw#0x}"; raw="${raw^^}"
    printf '%s' "$raw"
}

card_has_edp() {
    local cname="$1" entry bname status
    for entry in /sys/class/drm/"${cname}"-eDP-*; do
        [[ -d "$entry" ]] || continue
        bname=$(basename "$entry")
        [[ "$bname" == "${cname}-eDP-"* ]] || continue
        status=$(sysfs_read "$entry/status" "unknown")
        [[ "$status" == "disconnected" ]] && continue
        return 0
    done
    return 1
}

vram_size() {
    local dev="$1" v
    v=$(sysfs_read "$dev/mem_info_vram_total" "")
    if [[ -n "$v" && "$v" != "0" ]]; then
        printf '%d MiB' "$(( v / 1024 / 1024 ))"; return
    fi
    v=$(sysfs_read "$dev/prelim_total_memory" "")
    if [[ -n "$v" && "$v" != "0" ]]; then
        printf '%d MiB' "$(( v / 1024 / 1024 ))"; return
    fi
}

gpu_temp() {
    local dev="$1" hw temp_raw
    local hwmon_base="$dev/hwmon"
    [[ -d "$hwmon_base" ]] || return
    for hw in "$hwmon_base"/hwmon*; do
        [[ -d "$hw" ]] || continue
        temp_raw=$(sysfs_read "$hw/temp1_input" "")
        if [[ -n "$temp_raw" && "$temp_raw" =~ ^[0-9]+$ ]]; then
            printf '%d°C' "$(( temp_raw / 1000 ))"; return
        fi
    done
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# HUMAN-FRIENDLY GPU NAMES / Generic List Of Names
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
pci_friendly_name() {
    local dev="$1" label vid did dd

    label=$(sysfs_read "$dev/label")
    [[ -n "$label" ]] && { printf '%s' "$label"; return; }

    vid=$(sysfs_read "$dev/vendor" "0x0000"); vid=${vid#0x}; vid=${vid^^}
    did=$(sysfs_read "$dev/device" "0x0000"); did=${did#0x}; did=${did^^}
    dd=$(( 16#$did ))

    case "$vid" in
    10DE) # NVIDIA — generation by DID range : to-do ; add nvidia RTX 5000 series
        if   (( dd >= 0x2700 && dd <= 0x29FF )); then printf 'NVIDIA GeForce RTX 4000 series'
        elif (( dd >= 0x2200 && dd <= 0x26FF )); then printf 'NVIDIA GeForce RTX 3000 series'
        elif (( dd >= 0x1E00 && dd <= 0x21FF )); then printf 'NVIDIA GeForce RTX 2000 series'
        elif (( dd >= 0x1B00 && dd <= 0x1DFF )); then printf 'NVIDIA GeForce GTX 1000 series'
        elif (( dd >= 0x1300 && dd <= 0x13FF )); then printf 'NVIDIA GeForce GTX 900 series'
        elif (( dd >= 0x0FC0 && dd <= 0x0FFF )); then printf 'NVIDIA GeForce GTX 600 series'
        else                                          printf 'NVIDIA GeForce (generic name)'; fi ;;

    1002) # AMD — architecture by DID range : to-do ; add AMD RX 9000 series
        if   (( dd >= 0x7440 && dd <= 0x74FF )); then printf 'AMD Radeon RX 7000 series'
        elif (( dd >= 0x73A0 && dd <= 0x743F )); then printf 'AMD Radeon RX 6000 series'
        elif (( dd >= 0x6860 && dd <= 0x687F )); then printf 'AMD Radeon RX Vega series'
        elif (( dd >= 0x67C0 && dd <= 0x67FF )); then printf 'AMD Radeon RX 400/500 series'
        elif (( dd >= 0x1630 && dd <= 0x16BF )); then printf 'AMD Radeon Graphics (iGPU)'
        elif (( dd >= 0x15D8 && dd <= 0x15DF )); then printf 'AMD Radeon Vega (iGPU)'
        elif (( dd >= 0x1900 && dd <= 0x19FF )); then printf 'AMD Radeon 800M series (iGPU)'
        else                                          printf 'AMD Radeon (generic name)'; fi ;;

    8086) # Intel — generation by DID range : to-do ; add Intel ARC B series
        if   (( dd >= 0x56A0 && dd <= 0x56BF )); then printf 'Intel Arc A series'
        elif (( dd >= 0x5690 && dd <= 0x569F )); then printf 'Intel Arc A series (Mobile)'
        elif (( dd >= 0xA780 && dd <= 0xA7BF )); then printf 'Intel Iris Xe (Raptor Lake)'
        elif (( dd >= 0x46A0 && dd <= 0x46CF )); then printf 'Intel Iris Xe (Alder Lake)'
        elif (( dd >= 0x4680 && dd <= 0x469F )); then printf 'Intel UHD (Alder Lake)'
        elif (( dd >= 0x9A40 && dd <= 0x9A7F )); then printf 'Intel Iris Xe (Tiger Lake)'
        elif (( dd >= 0x8A50 && dd <= 0x8A7F )); then printf 'Intel Iris Plus (Ice Lake)'
        elif (( dd >= 0x9BC0 && dd <= 0x9BFF )); then printf 'Intel UHD (Comet Lake)'
        elif (( dd >= 0x3E00 && dd <= 0x3EFF )); then printf 'Intel UHD (Coffee Lake)'
        elif (( dd >= 0x5900 && dd <= 0x59FF )); then printf 'Intel HD (Kaby Lake)'
        else                                          printf 'Intel Graphics (generic name)'; fi ;;

    *) printf 'GPU [%s:%s]' "$vid" "$did" ;;
    esac
}


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# GPU DISCOVERY
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
declare -a cards=()
declare -A c_pci c_drv c_bootvga c_edp c_busnum c_model c_vid c_did c_class c_vram c_temp

for card_path in /sys/class/drm/card*; do
    cname=$(basename "$card_path")
    [[ "$cname" =~ ^card[0-9]+$ ]] || continue
    [[ -e "$card_path/device" ]]   || continue

    devpath=$(readlink -f "$card_path/device") || continue

    pci=$(basename "$devpath")
    c_pci["$cname"]="$pci"
    c_busnum["$cname"]=0
    [[ "$pci" =~ ^[0-9a-fA-F]{4}:[0-9a-fA-F]{2}:[0-9a-fA-F]{2}\.[0-9a-fA-F]$ ]] \
        && c_busnum["$cname"]=$(pci_bus_decimal "$pci")

    drv_tmp=$(basename "$(readlink -f "$card_path/device/driver" 2>/dev/null)" 2>/dev/null)
    c_drv["$cname"]="${drv_tmp:-none}"

    c_bootvga["$cname"]=$(sysfs_read "$card_path/device/boot_vga" "0")
    c_class["$cname"]=$(pci_class "$devpath")

    card_has_edp "$cname" && c_edp["$cname"]=1 || c_edp["$cname"]=0

    # Read and normalise vendor/device IDs — no bare `local` here
    raw_vid=$(sysfs_read "$devpath/vendor" "0x0000")
    raw_did=$(sysfs_read "$devpath/device" "0x0000")
    c_vid["$cname"]="${raw_vid#0x}"; c_vid["$cname"]="${c_vid[$cname]^^}"
    c_did["$cname"]="${raw_did#0x}"; c_did["$cname"]="${c_did[$cname]^^}"

    c_model["$cname"]=$(pci_friendly_name "$devpath")
    c_vram["$cname"]=$(vram_size "$devpath")
    c_temp["$cname"]=$(gpu_temp "$devpath")

    cards+=("$cname")
done

gpu_count=${#cards[@]}
[[ "$gpu_count" -gt 0 ]] || die "No DRM GPUs found under /sys/class/drm/"

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ROLE CLASSIFICATION — multi-signal scoring
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
declare -A c_role c_score
igpu="" dgpu="" confidence=0 reason=""

for c in "${cards[@]}"; do
    score=0

    # PCI class 030200 = 3D controller → always dGPU
    [[ "${c_class[$c]}" == "030200" ]] && (( score -= 50 ))

    # PCI class 030000 = VGA compatible → likely iGPU
    [[ "${c_class[$c]}" == "030000" ]] && (( score += 20 ))

    # eDP: real signal unless it's NVIDIA on Optimus (mirror)
    if [[ "${c_edp[$c]}" -eq 1 ]]; then
        if [[ "${c_drv[$c]}" == "nvidia" ]]; then
            (( score -= 10 ))   # Optimus mirror — not the real panel owner
        else
            (( score += 30 ))
        fi
    fi

    # boot_vga
    [[ "${c_bootvga[$c]}" == "1" ]] && (( score += 20 ))

    # PCI bus proximity to root
    bus_n=${c_busnum[$c]}
    (( bus_n == 0 )) && (( score += 10 ))
    (( bus_n > 0 && bus_n <= 2 )) && (( score += 5 ))

    # Driver signals
    [[ "${c_drv[$c]}" =~ ^(i915|xe)$    ]] && (( score += 25 ))
    [[ "${c_drv[$c]}" == "nvidia"        ]] && (( score -= 25 ))
    [[ "${c_drv[$c]}" =~ ^(amdgpu|radeon)$ ]] && (( score += 5 ))

    c_score["$c"]=$score
done

best_score=-99999
worst_score=99999
for c in "${cards[@]}"; do
    (( c_score[$c] > best_score ))  && { best_score=${c_score[$c]};  igpu="$c"; }
    (( c_score[$c] < worst_score )) && { worst_score=${c_score[$c]}; dgpu="$c"; }
done

igpu_score=${c_score[$igpu]}
if   (( igpu_score >= 50 )); then confidence=95; reason="eDP + driver signals"
elif (( igpu_score >= 35 )); then confidence=90; reason="strong driver/eDP match"
elif (( igpu_score >= 20 )); then confidence=80; reason="boot_vga + PCI class"
elif (( igpu_score >= 10 )); then confidence=65; reason="PCI bus position"
else                               confidence=50; reason="heuristic only"; fi

if [[ "$gpu_count" -eq 1 ]]; then
    c_role["${cards[0]}"]="sole"
    igpu="${cards[0]}"; dgpu=""
else
    for c in "${cards[@]}"; do
        if [[ "$c" == "$igpu" ]]; then c_role["$c"]="iGPU"
        else                           c_role["$c"]="dGPU"; fi
    done
fi

dri_idx() { printf '%s' "${1#card}"; }

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# DISPLAY HELPERS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
role_col() {
    case "${c_role[$1]}" in
        iGPU) printf '%s' "$IGPU_COL" ;;
        dGPU) printf '%s' "$DGPU_COL" ;;
        sole) printf '%s' "$SOLE_COL" ;;
        *)    printf '%s' "$C_GRY"    ;;
    esac
}

role_badge() {
    local col; col=$(role_col "$1")
    printf '%b' "${col}${BD}${c_role[$1]}${R}"
}

drv_col() {
    case "$1" in
        nvidia)         printf '%s' "$NV_COL"    ;;
        amdgpu|radeon)  printf '%s' "$AMD_COL"   ;;
        i915|xe)        printf '%s' "$INTEL_COL" ;;
        none)           printf '%s' "$C_GRY"     ;;
        *)              printf '%s' "$C_WHT"     ;;
    esac
}

drv_fmt() {
    local col; col=$(drv_col "$1")
    printf '%b' "${col}${BD}$1${R}"
}

vendor_col() {
    case "$1" in
        10DE) printf '%s' "$NV_COL"    ;;
        1002) printf '%s' "$AMD_COL"   ;;
        8086) printf '%s' "$INTEL_COL" ;;
        *)    printf '%s' "$C_WHT"     ;;
    esac
}

conf_fmt() {
    local n=$1 col
    (( n >= 90 )) && col="$C_GRN" || { (( n >= 70 )) && col="$C_YLW" || col="$C_RED"; }
    printf '%b' "${col}${BD}${n}%%${R}"
}

bool_fmt() {
    [[ "$1" == "1" ]] \
        && printf '%b' "${OK_COL}${BD}yes${R}" \
        || printf '%b' "${NO_COL}no${R}"
}

SEP() { say "  ${C_GRY}────────────────────────────────────────────${R}"; }

# Tree of card details
card_tree() {
    local c="$1" vcol
    vcol=$(vendor_col "${c_vid[$c]}")
    say "  ${C_GRY}│${R}"
    printf '%b' "  ${C_GRY}├─${R} ${DM}driver${R}      $(drv_fmt "${c_drv[$c]}")\n"
    printf '%b' "  ${C_GRY}├─${R} ${DM}pci${R}         ${C_WHT}${c_pci[$c]}${R}\n"
    printf '%b' "  ${C_GRY}├─${R} ${DM}vid:did${R}     ${vcol}${c_vid[$c]}${R}${C_GRY}:${R}${c_did[$c]}\n"
    printf '%b' "  ${C_GRY}├─${R} ${DM}boot_vga${R}    $(bool_fmt "${c_bootvga[$c]}")\n"
    printf '%b' "  ${C_GRY}├─${R} ${DM}edp${R}         $(bool_fmt "${c_edp[$c]}")\n"
    [[ -n "${c_vram[$c]}" ]] && \
        printf '%b' "  ${C_GRY}├─${R} ${DM}vram${R}        ${C_MAG}${BD}${c_vram[$c]}${R}\n"
    [[ -n "${c_temp[$c]}" ]] && \
        printf '%b' "  ${C_GRY}├─${R} ${DM}temp${R}        ${C_ORG}${BD}${c_temp[$c]}${R}\n"
    printf '%b' "  ${C_GRY}└─${R} ${DM}DRI_PRIME${R}   ${C_YLW}${BD}$(dri_idx "$c")${R}\n"
}

# Single-line card header
card_header() {
    local c="$1" vcol
    vcol=$(vendor_col "${c_vid[$c]}")
    printf '%b' "  ${vcol}${BD}${c}${R}  $(role_badge "$c")  ${BD}${C_WHT}${c_model[$c]}${R}\n"
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# --use-device RESOLUTION
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
resolve_device() {
    local input="$1" c
    for c in "${cards[@]}"; do
        case "$input" in
            "$c")    printf '%s' "$c"; return 0 ;;
            nvidia)  [[ "${c_drv[$c]}" == "nvidia" ]]           && printf '%s' "$c" && return 0 ;;
            amd)     [[ "${c_drv[$c]}" =~ ^(amdgpu|radeon)$ ]] && printf '%s' "$c" && return 0 ;;
            intel)   [[ "${c_drv[$c]}" =~ ^(i915|xe)$ ]]       && printf '%s' "$c" && return 0 ;;
        esac
    done; return 1
}

forced=""
if [[ -n "$selected_device" ]]; then
    forced=$(resolve_device "$selected_device") \
        || die "No GPU matched '$selected_device'. Try --list-devices."
fi

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# --interactive-choose
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
if [[ "$interactive" -eq 1 ]]; then
    [[ -t 0 ]] || die "--interactive-choose requires a TTY"
    say ""; say "  ${BD}${C_CYN}Select GPU${R}"; SEP
    declare -A imap; idx=1
    for c in "${cards[@]}"; do
        printf '%b' "  ${BD}${C_YLW}[${idx}]${R}  "
        card_header "$c" | sed 's/^  //'
        imap[$idx]="$c"; (( idx++ ))
    done
    say ""
    read -rp "  Choice [1-$((idx-1))]: " choice
    [[ -n "${imap[${choice:-}]:-}" ]] || die "Invalid selection."
    forced="${imap[$choice]}"
fi

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# --list-devices
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
if [[ "$list_devices" -eq 1 ]]; then
    say ""
    say "  ${BD}${C_CYN}Detected GPUs${R}  ${C_GRY}${gpu_count} found${R}"
    say ""
    for c in "${cards[@]}"; do
        card_header "$c"
        card_tree "$c"
        say ""
    done
    exit 0
fi

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# INFO-ONLY MODE  (no command supplied)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
if [[ "${#cmd_args[@]}" -eq 0 ]]; then
    say ""
    say "  ${BD}${C_CYN}GPU Detection${R}"
    SEP

    if [[ "$gpu_count" -eq 1 ]]; then
        c="${cards[0]}"
        printf '%b' "  ${DM}gpu${R}          "; card_header "$c" | sed 's/^  //'
        printf '%b' "  ${DM}driver${R}       $(drv_fmt "${c_drv[$c]}")\n"
    else
        i_vcol=$(vendor_col "${c_vid[$igpu]}")
        d_vcol=$(vendor_col "${c_vid[$dgpu]}")
        printf '%b' "  ${DM}igpu${R}         ${i_vcol}${BD}${igpu}${R}  ${C_WHT}${c_model[$igpu]}${R}\n"
        printf '%b' "  ${DM}dgpu${R}         ${d_vcol}${BD}${dgpu}${R}  ${C_WHT}${c_model[$dgpu]}${R}\n"
    fi
    printf '%b' "  ${DM}confidence${R}   $(conf_fmt "$confidence")  ${C_GRY}${reason}${R}\n"

    if [[ "$verbose" -eq 1 ]]; then
        say ""; SEP
        for c in "${cards[@]}"; do
            say ""
            card_header "$c"
            card_tree "$c"
        done
    fi
    say ""; exit 0
fi

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# EXEC MODE
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
if   [[ -n "$forced" ]]; then run="$forced"
elif [[ -n "$dgpu" ]];   then run="$dgpu"
else                          run="${cards[0]}"; fi

[[ -n "$run" ]] || die "No suitable GPU could be selected."

if [[ "$verbose" -eq 1 ]]; then
    printf '%b' "  ${C_GRY}[dgpu-run]${R}  ${BD}${run}${R}  $(drv_fmt "${c_drv[$run]}")  $(role_badge "$run")  ${DM}${c_model[$run]}${R}\n" >&2
fi

run_drv="${c_drv[$run]}"
prime_idx=$(dri_idx "$run")

case "$run_drv" in
    nvidia)
        export __NV_PRIME_RENDER_OFFLOAD=1
        export __NV_PRIME_RENDER_OFFLOAD_PROVIDER="NVIDIA-G0"
        export __GLX_VENDOR_LIBRARY_NAME=nvidia
        export __VK_LAYER_NV_optimus=NVIDIA_only
        export DRI_PRIME="$prime_idx"
        ;;
    amdgpu|radeon|i915|xe)
        export DRI_PRIME="$prime_idx"
        ;;
    none)
        warn "'${run}' has no bound driver — command may not use it."
        ;;
    *)
        export DRI_PRIME="$prime_idx"
        ;;
esac

exec "${cmd_args[@]}"